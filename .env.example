FLASK_ENV=development
SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
AUTO_INIT_DB=true
PORT=

# Base de datos local con Docker.
DATABASE_URL=mysql+pymysql://reguue2:BotPeluTFG@mysql:3306/BotPeluTFG

# En Render + Aiven se usará una URL parecida a esta:
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:PORT/defaultdb?charset=utf8mb4

# Zona horaria y reglas de reservas
APP_TZ=Europe/Madrid
DEFAULT_MIN_ADVANCE_MIN=30
DEFAULT_MAX_DIAS_RESERVA=60

# WhatsApp Cloud API (configurar en Meta for Developers)
WABA_TOKEN=
WABA_VERIFY_TOKEN=pon_aqui_tu_verify_token
WABA_APP_SECRET=
GRAPH_API_VERSION=v23.0

# OpenAI (parsing de fechas/nombres y FAQ del bot)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
